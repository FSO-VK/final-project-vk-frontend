{
  "name": "final-project-vk-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development node ./server.js",
    "prod-build:client": "tsc -b && vite build --mode=production --outDir=dist/prod/client --ssrManifest",
    "prod-build:server": "tsc -b && vite build --mode=production --outDir=dist/prod/server --ssr src/entry-server.tsx",
    "staging-build:client": "tsc -b && vite build --mode=staging --outDir=dist/staging/client --ssrManifest",
    "staging-build:server": "tsc -b && vite build --mode=staging --outDir=dist/staging/server --ssr src/entry-server.tsx",
    "preview": "vite preview",
    "lint": "npx eslint .",
    "format": "npx prettier . --write",
    "prepare": "husky",
    "generate-pwa-icons": "pwa-assets-generator",
    "test": "echo no-tests"
  },
  "dependencies": {
    "@solidjs/router": "^0.15.3",
    "compression": "^1.8.1",
    "express": "^5.1.0",
    "sirv": "^3.0.2",
    "solid-js": "^1.9.4",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@eslint/css": "^0.11.1",
    "@eslint/js": "^9.36.0",
    "@eslint/json": "^0.13.2",
    "@eslint/markdown": "^7.3.0",
    "@feature-sliced/cli": "^1.0.0",
    "@types/node": "^24.6.2",
    "@vite-pwa/assets-generator": "^0.2.6",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "jiti": ">=2.6.1",
    "lint-staged": "^16.2.3",
    "postcss": "^8.5.6",
    "postcss-nested": "^7.0.2",
    "prettier": "3.6.2",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.45.0",
    "vite": "^6.0.11",
    "vite-plugin-pwa": "^0.21.1",
    "vite-plugin-solid": "^2.11.0",
    "workbox-window": "^7.3.0"
  },
  "overrides": {
    "sharp": "0.32.6",
    "sharp-ico": "0.1.5"
  },
  "lint-staged": {
    "*.{tsx,ts,js,cjs,mjs,mts,cts,json,css}": "eslint --cache --fix -c ./eslint.config.ts",
    "*.{tsx,ts,js,cjs,mjs,mts,cts,json,css,md,json}": "prettier --write"
  },
  "postcss": {
    "plugins": {
      "postcss-nested": {}
    }
  }
}
