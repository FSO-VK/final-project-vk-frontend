    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/css": "^0.11.1",
    "@eslint/js": "^9.36.0",
    "@eslint/json": "^0.13.2",
    "@eslint/markdown": "^7.3.0",
    "@vite-pwa/assets-generator": "^0.2.6",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.4.0",
    "husky": "^9.1.7",
    "jiti": ">=2.6.1",
    "lint-staged": "^16.2.3",
    "prettier": "3.6.2",
    "typescript": "~5.6.0",
    "typescript-eslint": "^8.45.0",
    "vite": "^6.3.6",
    "vite-plugin-pwa": "^0.21.2",
    "workbox-core": "^7.3.0",
    "workbox-precaching": "^7.3.0",
    "workbox-routing": "^7.3.0",
    "workbox-strategies": "^7.3.0",
    "workbox-window": "^7.3.0"
  },
  "overrides": {
    "sharp": "0.32.6",
    "sharp-ico": "0.1.5"
